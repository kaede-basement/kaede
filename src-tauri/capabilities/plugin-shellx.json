{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "plugin-shellx",
  "description": "manages the shellx:* permissions",
  "windows": [
    "*"
  ],
  "permissions": [
    "shellx:allow-execute",
    "shellx:allow-spawn",
    "shellx:allow-stdin-write",
    "shellx:allow-kill",
    "shellx:allow-open"
  ]
}
