{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "plugin-os",
  "description": "manages the os:* permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "os:allow-arch",
    "os:allow-exe-extension",
    "os:allow-family",
    "os:allow-locale",
    "os:allow-os-type",
    "os:allow-platform",
    "os:allow-version"
  ]
}