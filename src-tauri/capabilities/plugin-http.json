{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "plugin-http",
  "description": "enables the http:* permissions",
  "windows": [
    "*"
  ],
  "permissions": [
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*" },
        { "url": "http://127.0.0.1" },
        { "url": "http://127.0.0.1:*" },
        { "url": "http://localhost" },
        { "url": "http://localhost:*" }
      ]
    },
    "http:allow-fetch",
    "http:allow-fetch-cancel",
    "http:allow-fetch-read-body",
    "http:allow-fetch-send"
  ]
}
