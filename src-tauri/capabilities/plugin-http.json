{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "plugin-http",
  "description": "enables the http:* permissions",
  "windows": [
    "*"
  ],
  "permissions": [
    "http:allow-fetch",
    "http:allow-fetch-cancel",
    "http:allow-fetch-read-body",
    "http:allow-fetch-send"
  ]
}