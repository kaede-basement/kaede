{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "plugin-shell",
  "description": "manages the shell:* permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "shell:allow-execute",
    "shell:allow-kill",
    "shell:allow-open",
    "shell:allow-spawn",
    "shell:allow-stdin-write"
  ]
}